---
import { site } from '../../data/site';
---

<section class="hero">
  <div class="wrap hero__grid">
    <div>
      <span class="eyebrow">{site.tagline}</span>
      <h1>Webs <em>a medida</em> para tu negocio, sin complicaciones.</h1>
      <p class="hero__sub">
        Diseño y programo páginas web rápidas, con base de datos cuando hace falta,
        adaptadas a lo que tu negocio necesita — y con precios que encajan en tu presupuesto.
      </p>
      <div class="hero__actions">
        <a href="#contacto" class="btn btn--primary">Pide tu presupuesto →</a>
        <a href="#servicios" class="btn btn--ghost">Ver lo que hago</a>
      </div>
      <div class="hero__meta">
        <div><b>A medida</b>Sin plantillas genéricas</div>
        <div><b>Base de datos</b>Reservas, paneles, catálogos</div>
        <div><b>Precio claro</b>Presupuesto cerrado</div>
      </div>
    </div>

    <div class="build" aria-hidden="true">
      <span class="build__tag">construyendo tu web…</span>
      <div class="build__bar">
        <i></i><i></i><i></i>
        <span class="build__url">https://tunegocio.com</span>
      </div>
      <div class="build__body">
        <div class="blk blk--head"></div>
        <div class="blk--row">
          <div class="blk blk--card"></div>
          <div class="blk blk--card2"></div>
        </div>
        <div class="blk blk--data">
          <div class="dr"><span class="tag">clientes</span><b>SELECT *</b></div>
          <div class="dr"><span>reserva_id</span><b>#A-2048</b></div>
          <div class="dr"><span>estado</span><b>confirmada ✓</b></div>
          <div class="dr"><span>productos</span><b>128 filas</b></div>
        </div>
      </div>
    </div>
  </div>
</section>
