---
import { proyectos } from '../../data/proyectos';
import { site } from '../../data/site';
---

{
  proyectos.length > 0 && (
    <section class="section" id="proyectos">
      <div class="wrap">
        <div class="section__head reveal">
          <span class="eyebrow">Proyectos</span>
          <h2>Algunos trabajos</h2>
          <p>Una muestra de webs que he construido. Si quieres algo parecido para tu negocio, hablamos.</p>
        </div>
        <div class="grid-proj">
          {proyectos.map((p) => {
            const Tag = p.url ? 'a' : 'div';
            const attrs = p.url ? { href: p.url, target: '_blank', rel: 'noopener' } : {};
            return (
              <Tag class="proj reveal" {...attrs}>
                <div class="proj__img">
                  {p.imagen ? <img src={p.imagen} alt={p.titulo} /> : <span style="font-size:2rem;opacity:.4">{site.mark}</span>}
                </div>
                <div class="proj__body">
                  <h3>{p.titulo}</h3>
                  <p>{p.descripcion}</p>
                </div>
              </Tag>
            );
          })}
        </div>
      </div>
    </section>
  )
}
