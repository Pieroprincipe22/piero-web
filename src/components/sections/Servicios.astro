---
import { servicios } from '../../data/servicios';

const iconos: Record<string, string> = {
  web: '<rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 21h8"/>',
  db: '<ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6"/>',
  code: '<path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/>',
  precio: '<path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
};
---

<section class="section" id="servicios">
  <div class="wrap">
    <div class="section__head reveal">
      <span class="eyebrow">Servicios</span>
      <h2>Lo que puedo construir para ti</h2>
      <p>Desde una web sencilla para que te encuentren, hasta sistemas completos con base de datos. Tú decides hasta dónde llegar.</p>
    </div>
    <div class="grid-serv">
      {
        servicios.map((s) => (
          <div class={`card reveal${s.acento ? ' card--accent' : ''}`}>
            <div class="card__ico">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={iconos[s.icono]} />
            </div>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
