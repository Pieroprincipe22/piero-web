# ── Copia este archivo como ".env" y rellena tus claves reales ──
# (en Vercel, añade estas mismas variables en Settings → Environment Variables)

# Supabase  (Project Settings → API)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Usa la "service_role key" (NO la anon). Es secreta: solo se usa en el servidor.
SUPABASE_SERVICE_KEY=tu_service_role_key

# Resend  (https://resend.com → API Keys)
RESEND_API_KEY=tu_api_key_de_resend
# Email DESDE el que se envía el aviso. Debe ser de un dominio verificado en Resend.
# Mientras verificas tu dominio puedes usar: onboarding@resend.dev
MAIL_FROM=Piero Web <onboarding@resend.dev>
# Email DONDE quieres recibir los avisos de cada cliente nuevo:
MAIL_TO=tu@email.com
